{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blendsdk/codex-codeops/schemas/codeops-config.schema.json",
  "title": "CodeOps project configuration",
  "type": "object",
  "required": ["schema", "mode", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": 1},
    "mode": {"enum": ["strict", "adaptive"]},
    "artifacts": {
      "type": "object",
      "required": ["layout", "root"],
      "additionalProperties": false,
      "properties": {
        "layout": {"enum": ["nested", "flat"]},
        "root": {"type": "string", "minLength": 1}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "independentReview": {"type": "boolean"},
        "minimumReviewers": {"type": "integer", "minimum": 1},
        "stopOnMajorFinding": {"type": "boolean"}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"}
      }
    }
  }
}
